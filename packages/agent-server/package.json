{
  "name": "@novel-agent/agent-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate:chapters": "tsx --env-file=../../.env src/scripts/migrate-source-chapters-to-sqlite.ts",
    "migrate:chats": "tsx --env-file=../../.env src/scripts/migrate-chats-to-sqlite.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@mariozechner/pi-agent-core": "^0.64.0",
    "@mariozechner/pi-ai": "^0.64.0",
    "@mariozechner/pi-coding-agent": "^0.64.0",
    "@novel-agent/shared": "workspace:*",
    "@sinclair/typebox": "^0.34",
    "better-sqlite3": "^12.9.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.6.12"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^1.0.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^1.0.4"
  }
}
