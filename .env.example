# 小说分析 pipeline 走 DeepSeek（需要严格 JSON mode；千帆 qianfan 实测 JSON mode 输出不严格会解析失败）。
# Auto-title 默认走下面的 AGENT_*，没设时 fallback 到 DeepSeek。
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Agent 对话 + 正文写作（OpenAI-compatible；默认百度千帆 qianfan-code-latest，换 provider 只改这三个变量）
AGENT_API_KEY=
AGENT_MODEL=qianfan-code-latest
AGENT_BASE_URL=https://qianfan.baidubce.com/v2/coding

# Server
PORT=3100

# Storage（可选）：数据目录。
# - 不设 → 默认 ~/.novel-agent/data
# - 相对路径 → 相对仓库根（找 pnpm-workspace.yaml 定位）
# - 绝对路径 → 直接用（部署生产时常用，例如 /var/lib/novel-agent/data）
# data/ 已在 .gitignore
# NOVEL_AGENT_DATA_DIR=./data
