# Analysis pipeline (参考小说分析用便宜模型)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Agent 对话 + 正文写作（OpenAI-compatible；默认百度千帆 qianfan-code-latest，换 provider 只改这三个变量）
AGENT_API_KEY=
AGENT_MODEL=qianfan-code-latest
AGENT_BASE_URL=https://qianfan.baidubce.com/v2/coding

# Server
PORT=3100

# Storage（可选）：数据目录绝对路径。不设默认 ~/.novel-agent/data
# 推荐设到项目内方便开发查看；data/ 已在 .gitignore
# NOVEL_AGENT_DATA_DIR=/absolute/path/to/novel-agent/data
